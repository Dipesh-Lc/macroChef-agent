# Safe local default. Use mock mode unless you intentionally configure a provider.
MODEL_PROVIDER=mock
MODEL_PROVIDER_FALLBACKS=mock

# Frontend API target used by Streamlit outside Docker.
MACROCHEF_API_URL=http://localhost:8000

# Gemini / Google AI
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_VERSION=v1beta
GEMINI_CHAT_MODEL=
GEMINI_CHAT_MODEL_FALLBACKS=
GEMINI_VISION_MODEL=
GEMINI_VISION_MODEL_FALLBACKS=
GEMINI_THINKING_LEVEL=low
GEMINI_THINKING_BUDGET=

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=
OPENAI_VISION_MODEL=

# Anthropic / Claude
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_API_VERSION=2023-06-01
ANTHROPIC_CHAT_MODEL=
ANTHROPIC_VISION_MODEL=

# Ollama / local OpenAI-compatible provider
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=
OLLAMA_VISION_MODEL=

MODEL_TIMEOUT_SECONDS=30
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_PATH=./data/chroma
DATABASE_URL=sqlite:///./macrochef.db
